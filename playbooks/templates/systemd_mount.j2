[Unit]
Description=Montage Samba {{ partage.key }}
After=network-online.target
Wants=network-online.target

[Mount]
What=//{{ nas_ip }}/{{ partage.key }}
Where={{ target_mount_path }}
Type=cifs
Options=credentials=/etc/nascredentials,_netdev,nofail,uid=1000,gid=1000,file_mode=0664,dir_mode=0775,iocharset=utf8,vers=3.0

[Install]
WantedBy=multi-user.target